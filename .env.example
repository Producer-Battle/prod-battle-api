NODE_ENV=development
PORT=8080

# Postgres
DATABASE_URL=postgres://prodbattle:prodbattle@localhost:5432/prod_battle

# Redis (pub/sub + leader election + hot state)
REDIS_URL=redis://localhost:6379

# Wasabi Object Storage (S3-compatible). Pick the region matching the
# bucket (eu-central-2 is the prod default; see prod-battle-infra storage
# module). S3_ACCESS_KEY / S3_SECRET_KEY are Wasabi sub-account credentials
# scoped to this bucket only.
S3_ENDPOINT=https://s3.eu-central-2.wasabisys.com
S3_REGION=eu-central-2
S3_BUCKET=prod-battle-audio
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Scaleway Serverless Jobs - ffmpeg transcoder
SCW_JOB_FFMPEG_ID=
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_PROJECT_ID=

# Auth (better-auth)
AUTH_SECRET=change-me-32-bytes-of-random
AUTH_TRUSTED_ORIGINS=http://localhost:5173,https://producer-battle.app

# Public base URL of the web app (for email links, CORS)
WEB_ORIGIN=http://localhost:5173

# Freesound.org - register a token at https://freesound.org/apiv2/apply/
# Only needed to (re)populate the stem pool. Match creation doesn't call
# Freesound live; it picks from the already-stored pool.
FREESOUND_API_KEY=

# Mollie - recurring Supporter subscription billing. test_... for sandbox,
# live_... for production. Empty = billing disabled (checkout returns 503).
# Dashboard: https://my.mollie.com/dashboard/developers/api-keys
MOLLIE_API_KEY=
