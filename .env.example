NODE_ENV=development
PORT=8080

# Postgres
DATABASE_URL=postgres://prodbattle:prodbattle@localhost:5432/prod_battle

# Redis (pub/sub + leader election + hot state)
REDIS_URL=redis://localhost:6379

# Scaleway Object Storage (S3-compatible)
S3_ENDPOINT=https://s3.fr-par.scw.cloud
S3_REGION=fr-par
S3_BUCKET=prod-battle-audio-staging
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Scaleway Serverless Jobs — ffmpeg transcoder
SCW_JOB_FFMPEG_ID=
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_PROJECT_ID=

# Auth (better-auth)
AUTH_SECRET=change-me-32-bytes-of-random
AUTH_TRUSTED_ORIGINS=http://localhost:5173,https://producer-battle.app

# Public base URL of the web app (for email links, CORS)
WEB_ORIGIN=http://localhost:5173
